{
  "name": "@vosslang/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "codegen": "openapi-typescript ../../contracts/openapi.json -o src/generated/types.ts",
    "check:core-imports": "depcruise --config .dependency-cruiser.cjs dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dependency-cruiser": "17.4.3",
    "eventsource-parser": "3.1.0",
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "7.13.0",
    "tsup": "8.5.1",
    "typescript": "^5.6.0",
    "vitest": "4.1.8"
  }
}
