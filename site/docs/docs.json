  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "label": "Marketing",
        "href": "https://voss.dev"
      },
      {
        "label": "Orchestration",
        "href": "/orchestration/overview"
      },
      {
        "label": "Harness",
        "href": "/harness/overview"
      },
      {
        "label": "Language",
        "href": "/language/overview"
      },
      {
        "label": "Roadmap",
        "href": "/roadmap/v0-1"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/bm9797/Voss"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "Harness",
            "href": "/harness/overview"
          },
          {
            "label": "Language",
            "href": "/language/overview"
          },
          {
            "label": "Security",
            "href": "/security/overview"
          }
        ]
      },
      {
        "header": "Source",
