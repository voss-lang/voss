{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Voss Docs",
  "description": "Documentation for the Voss coding harness and .voss workflow-control language.",
  "colors": {
    "primary": "#c2410c",
    "light": "#ff7a45",
    "dark": "#c2410c"
  },
  "logo": {
