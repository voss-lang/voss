    use voss_auth::Resolution;
    use voss_providers::{AnthropicOAuthProvider, ModelProvider};

    /// Build a provider from a resolved auth path. R7 only supports Anthropic OAuth.
    /// Other paths return a clear error pointing at the future wave that will land them.
    pub fn build(res: Resolution) -> anyhow::Result<Box<dyn ModelProvider>> {
