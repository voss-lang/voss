    ```rust
    use std::process::Command;
    use std::path::PathBuf;
    use voss_tools::default_toolset;

    fn extract_props(schema: &serde_json::Value) -> std::collections::BTreeSet<String> {
        schema.get("properties").and_then(|v| v.as_object())
            .map(|m| m.keys().cloned().collect()).unwrap_or_default()
    }

    fn extract_required(schema: &serde_json::Value) -> std::collections::BTreeSet<String> {
        schema.get("required").and_then(|v| v.as_array())
            .map(|a| a.iter().filter_map(|v| v.as_str().map(String::from)).collect())
            .unwrap_or_default()
    }

    #[test]
    fn all_9_tool_schemas_match_python() {
        let py_out = match Command::new("python3")
            .args(["scripts/dump_python_tool_schemas.py"])
            .output() {
            Ok(o) if o.status.success() => o.stdout,
            _ => { eprintln!("skipping: python3 voss not importable"); return; }
        };
        let py: serde_json::Value = serde_json::from_slice(&py_out).expect("python schema dump");

        let cwd = PathBuf::from(".");
        let tools = default_toolset(&cwd);
        assert_eq!(tools.len(), 9, "expected 9 tools, got {}", tools.len());

        for tool in &tools {
            let name = tool.name();
            let py_entry = py.get(name).unwrap_or_else(|| panic!("python missing tool {name}"));
            let py_schema = py_entry.get("parameters").unwrap();
            let rs_schema = tool.schema();

            let py_props = extract_props(py_schema);
            let rs_props = extract_props(&rs_schema);
            // Tools with no Python parameters surface as empty schema; allow that case
            // but if Python lists props, Rust must list the same set.
            if !py_props.is_empty() {
                assert_eq!(py_props, rs_props, "{name} property name set drift");
            }
            let py_req = extract_required(py_schema);
            let rs_req = extract_required(&rs_schema);
            // Required is allowed to be empty on either side if Python does not surface it.
            // If Python lists required, Rust must match.
            if !py_req.is_empty() {
                assert_eq!(py_req, rs_req, "{name} required-set drift");
            }
        }
    }

    #[test]
    fn is_mutating_flags_match_d12() {
        let cwd = PathBuf::from(".");
        let tools = default_toolset(&cwd);
        let mutating: std::collections::BTreeSet<&str> = tools.iter()
            .filter(|t| t.is_mutating()).map(|t| t.name()).collect();
        let read_only: std::collections::BTreeSet<&str> = tools.iter()
            .filter(|t| !t.is_mutating()).map(|t| t.name()).collect();
        let expected_mutating: std::collections::BTreeSet<&str> =
            ["fs_write","fs_edit","shell_run"].into_iter().collect();
        let expected_read: std::collections::BTreeSet<&str> =
            ["fs_read","fs_glob","fs_grep","git_status","git_diff","voss_check"].into_iter().collect();
        assert_eq!(mutating, expected_mutating, "D-12 mutating set drift");
        assert_eq!(read_only, expected_read, "D-12 read-only set drift");
    }
    ```
