def _binop_chain(file, meta, children):
    if len(children) == 1:
        return children[0]
    node = children[0]
    i = 1
    while i < len(children):
        op = str(children[i])
        right = children[i + 1]
        node = BinOp(span=Span(file=file, line_start=meta.line, col_start=meta.column,
                               line_end=meta.end_line, col_end=meta.end_column),
                     op=op, left=node, right=right)
        i += 2
    return node

def _left_assoc(file, meta, children, op_filter):
    if len(children) == 1:
        return children[0]
    node = children[0]
    op = op_filter(None)
    for right in children[1:]:
