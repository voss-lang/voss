    use assert_cmd::Command;
    use std::time::Instant;

    /// Cold-start perf check. Phase 7 success criterion: voss --version ≤ 50ms on macOS arm64.
    /// We measure the wall clock and warn (not fail) if it exceeds the target — fast machines
    /// will easily make it; slow CI runners may not, and we don't want CI flake.
    #[test]
    fn version_under_target_or_warn() {
        // Warm the OS file cache by running once before measuring.
        let _ = Command::cargo_bin("voss-cli").unwrap().arg("--version").output();

        let start = Instant::now();
        let out = Command::cargo_bin("voss-cli").unwrap().arg("--version").output().unwrap();
        let elapsed = start.elapsed();
        assert!(out.status.success(), "voss-cli --version failed");
        let s = String::from_utf8_lossy(&out.stdout);
        assert!(s.contains("voss"), "expected version output, got: {s}");

        let target_ms = 50u128;
        let actual_ms = elapsed.as_millis();
        if actual_ms > target_ms {
            eprintln!("WARN: voss --version took {}ms (target {}ms). \
                Investigate before declaring R7/R9 done on macOS arm64.",
                actual_ms, target_ms);
        }
        // Hard cap at 5x target (250ms) — anything slower indicates a real regression.
        assert!(actual_ms < 5 * target_ms,
            "voss --version took {}ms, > 5x target {}ms — perf regression",
            actual_ms, target_ms);
    }
    ```
