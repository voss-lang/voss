@dataclass(frozen=True, slots=True)
class QualName(Node):
    parts: tuple[str, ...]      # e.g. ("memory", "episodic")

@dataclass(frozen=True, slots=True)
class TypeKwarg(Node):
    name: str                   # e.g. "capacity"
