{
  "files.associations": {
    "*.voss": "python"
  },
  "python.analysis.exclude": [
    "**/*.voss"
  ],
  "python.analysis.ignore": [
    "**/*.voss"
  ],
  "pylint.ignorePatterns": [
    "**/*.voss"
  ],
  "ruff.lint.ignore": [
    "**/*.voss"
  ],
  "haskell.plugin.hlint.globalOn": false,
  "haskell.plugin.hlint.diagnosticsOn": false,
  "files.exclude": {
    "**/dist-newstyle/**": true
  },
  "files.watcherExclude": {
    "**/dist-newstyle/**": true,
    "**/target/**": true
  },
  "rust-analyzer.linkedProjects": ["./Cargo.toml"],
  "rust-analyzer.files.excludeDirs": ["tests/eval/matrix", "target"],
  "search.exclude": {
    "**/dist-newstyle/**": true
  },
  "[python]": {
    "editor.formatOnSave": false
  },
  "workbench.colorTheme": "Bearded Theme Anthracite"
}